{
  /**
   * TypeScript Configuration — Application (Browser)
   * -------------------------------------------------
   * Конфигурация для исходного кода React-приложения (папка src/).
   *
   * Оптимизирован для:
   * - Современных браузеров (ES2023)
   * - Bundler-режима (Vite)
   * - Строгой проверки типов
   */
  "compilerOptions": {
    /* ═══════════════════════════════════════════════════════════════════════
     * Build Info — Инкрементальная компиляция
     * ═══════════════════════════════════════════════════════════════════════ */

    /** Путь к кэшу сборки для ускорения повторных компиляций */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* ═══════════════════════════════════════════════════════════════════════
     * Language & Environment — Целевая платформа
     * ═══════════════════════════════════════════════════════════════════════ */

    /** Версия ECMAScript для генерируемого кода */
    "target": "ES2023",

    /**
     * Доступные типы и API:
     * - ES2023: современные методы массивов, Object, Promise и т.д.
     * - DOM: window, document, HTMLElement и все Web API
     * - DOM.Iterable: итерация по NodeList, HTMLCollection
     */
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    /** Формат модулей (ESNext = ES Modules с динамическим import()) */
    "module": "ESNext",

    /** Типы для Vite-специфичных API (import.meta.env, import.meta.glob) */
    "types": ["vite/client"],

    /** Пропуск проверки типов в node_modules для ускорения сборки */
    "skipLibCheck": true,

    /** Игнорировать предупреждения о deprecated опциях */
    "ignoreDeprecations": "6.0",

    /* ═══════════════════════════════════════════════════════════════════════
     * Bundler Mode — Режим работы с бандлером (Vite)
     * ═══════════════════════════════════════════════════════════════════════ */

    /**
     * Разрешение модулей в стиле бандлера:
     * - Поддержка package.json exports
     * - Автоматическое разрешение index файлов
     */
    "moduleResolution": "Bundler",

    /** Разрешить импорты с .ts/.tsx расширениями (Vite их обработает) */
    "allowImportingTsExtensions": true,

    /**
     * Строгая обработка import/export:
     * - Требует `type` для импорта только типов: import type { User } from './types'
     * - Улучшает tree-shaking и совместимость с ESM
     */
    "verbatimModuleSyntax": true,

    /** Принудительно считать все файлы модулями (не скриптами) */
    "moduleDetection": "force",

    /** Не генерировать JS файлы (этим занимается Vite) */
    "noEmit": true,

    /** JSX трансформация через React 17+ автоматический runtime */
    "jsx": "react-jsx",

    /* ═══════════════════════════════════════════════════════════════════════
     * Path Aliases — Алиасы путей (опционально)
     * ═══════════════════════════════════════════════════════════════════════ */

    /** Базовый путь для разрешения не-относительных импортов */
    "baseUrl": ".",

    /**
     * Алиасы для удобных импортов:
     * Вместо: import { Button } from '../../../components/ui/Button'
     * Пишем:  import { Button } from '@/components/ui/Button'
     */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* ═══════════════════════════════════════════════════════════════════════
     * Linting — Строгие проверки кода
     * ═══════════════════════════════════════════════════════════════════════ */

    /** Ошибка при неиспользуемых локальных переменных */
    "noUnusedLocals": true,

    /** Ошибка при неиспользуемых параметрах функций */
    "noUnusedParameters": true,

    /** Запретить декораторы и другой не-erasable синтаксис */
    "erasableSyntaxOnly": true,

    /** Требовать break/return в каждом case блоке switch */
    "noFallthroughCasesInSwitch": true,

    /** Включить все строгие проверки типов */
    "strict": true
  },

  /** Папки/файлы для компиляции */
  "include": ["src"]
}
